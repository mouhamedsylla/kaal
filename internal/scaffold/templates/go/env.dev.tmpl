# {{.Name}} — development environment
# This file is loaded by docker compose for the dev environment.
# Never commit secrets — use a secret manager for production.

GO_ENV=development
API_PORT={{.Port}}

{{- if .HasDB}}

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME={{.Name}}_dev
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@db:5432/{{.Name}}_dev?sslmode=disable
{{- end}}
